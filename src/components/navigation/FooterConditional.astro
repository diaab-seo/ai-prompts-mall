---
import categories from '../../data/categories.json';

interface Props { pageType?: string }
const { pageType = 'homepage' } = Astro.props;

// Build context-aware footer links
const allCategories = categories;
---

<footer class="site-footer" role="contentinfo" aria-label="Site footer">
  <div class="container footer-inner">

    <!-- Brand column -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="AI Prompts Mall home">
        <strong>AI<span>Prompts</span>Mall</strong>
      </a>
      <p class="footer-tagline">
        Discover the best open-source AI tools,<br />
        curated from GitHub and ranked by stars.
      </p>
      <p class="footer-domain">aipromptsmall.shop</p>
    </div>

    <!-- Categories column -->
    <nav aria-label="Category navigation" class="footer-nav">
      <p class="footer-nav-label">Categories</p>
      <ul role="list">
        {allCategories.slice(0, 7).map((c) => (
          <li><a href={`/category/${c.slug}`}>{c.label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- More Categories -->
    <nav aria-label="More categories" class="footer-nav">
      <p class="footer-nav-label">More</p>
      <ul role="list">
        {allCategories.slice(7).map((c) => (
          <li><a href={`/category/${c.slug}`}>{c.label}</a></li>
        ))}
        <li><a href="/trending">🔥 Trending</a></li>
        <li><a href="/search">🔍 Search</a></li>
      </ul>
    </nav>

    <!-- Explore column -->
    <nav aria-label="Explore navigation" class="footer-nav">
      <p class="footer-nav-label">Explore</p>
      <ul role="list">
        <li><a href="/trending">Trending Repos</a></li>
        <li><a href="/search">Full-Text Search</a></li>
        {pageType === 'repo' && <li><a href="/category/large-language-models">LLMs</a></li>}
        {pageType === 'repo' && <li><a href="/category/ai-agents">AI Agents</a></li>}
      </ul>
    </nav>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {new Date().getFullYear()} aipromptsmall.shop — Open-source AI tools directory. Data sourced from GitHub API.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-block: 3rem;
  }

  .footer-brand {}
  .footer-logo {
    display: inline-block;
    text-decoration: none;
    color: var(--color-text);
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
  }
  .footer-logo strong { font-weight: 800; }
  .footer-logo span { color: var(--color-accent); }
  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }
  .footer-domain {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.04em;
  }

  .footer-nav {}
  .footer-nav-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .footer-nav ul { list-style: none; }
  .footer-nav li { margin-bottom: 0.375rem; }
  .footer-nav a {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--color-text); }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-block: 1.25rem;
  }
  .footer-bottom p {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 540px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>
