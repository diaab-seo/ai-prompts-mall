---
/**
 * BackToTop.astro — Floating scroll-to-top button, appears after scrolling 400px
 */
---

<button
  id="back-to-top"
  class="btt-btn"
  aria-label="Back to top"
  title="Back to top"
  hidden
>
  <svg
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M18 15l-6-6-6 6"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('back-to-top') as HTMLButtonElement;
  if (btn) {
    // Show/hide based on scroll position
    const onScroll = () => {
      btn.hidden = window.scrollY < 400;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Scroll to top on click
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style>
  .btt-btn {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 200;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    transition: background 0.15s, transform 0.15s, opacity 0.2s, box-shadow 0.15s;
    opacity: 0;
    animation: fade-in-btt 0.25s ease forwards;
  }

  .btt-btn[hidden] {
    display: none;
  }

  .btt-btn:not([hidden]) {
    opacity: 1;
  }

  .btt-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 85%, #000);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .btt-btn:active {
    transform: translateY(0);
  }

  @keyframes fade-in-btt {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .btt-btn { bottom: 1rem; right: 1rem; width: 40px; height: 40px; }
  }
</style>
