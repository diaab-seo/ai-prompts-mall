---
/**
 * /search — Instant client-side search over manifest data.
 * Works in dev AND production without PageFind.
 * Optionally supplements with PageFind full-text search in production.
 */
import Base from '../layouts/Base.astro';
import manifestRaw from '../data/manifest.json';
import categories from '../data/categories.json';

const title = 'Search AI Tools — aipromptsmall.shop';
const description = 'Search 1,278+ open-source AI tools, LLMs, agents, prompts, and frameworks by name, description, or topic.';
const canonical = 'https://aipromptsmall.shop/search';

// Build a compact search index (name, owner, description, topics, category)
// Keep it small: only the fields we need for client-side search
const searchIndex = (manifestRaw as any[]).map((r: any) => ({
  n: r.repo,
  o: r.owner,
  d: r.description ?? '',
  t: (r.topics ?? []).join(' '),
  c: r.primary_category,
  s: r.stars,
  l: r.language ?? '',
}));

const catMap = Object.fromEntries(categories.map((c) => [c.slug, c.label]));

// Popular topics for the suggestions
const popularTopics = [
  'llm','rag','langchain','openai','agents','huggingface','pytorch','fine-tuning',
  'vector-database','embeddings','chatgpt','transformers','mistral','llama','gemma',
  'claude','ollama','deepseek','prompt-engineering','rlhf','multimodal','vllm','lora',
  'benchmark','safety','alignment','sdk','inference','training','diffusion',
];
---

<Base title={title} description={description} canonical={canonical} pageType="search">
  <div class="search-page container">

    <header class="search-header">
      <h1 class="search-title">Find <span class="grad">AI Tools</span></h1>
      <p class="search-subtitle">
        Search across <strong>1,278+</strong> open-source AI repositories — by name, description, or topic.
      </p>
    </header>

    <!-- Search box -->
    <div class="search-box-wrap" role="search">
      <div class="search-input-row">
        <label for="search-input" class="search-icon" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </label>
        <input
          id="search-input"
          type="search"
          class="search-input"
          placeholder="Search repos, topics, descriptions…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search AI tools"
          aria-describedby="search-count"
        />
        <button id="search-clear" class="search-clear" aria-label="Clear search" hidden>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Category filter -->
      <div class="filter-row">
        <label for="cat-filter" class="filter-label">Category:</label>
        <select id="cat-filter" class="filter-select" aria-label="Filter by category">
          <option value="">All categories</option>
          {categories.map((c) => <option value={c.slug}>{c.label}</option>)}
        </select>
        <span id="search-count" class="search-count" aria-live="polite" aria-atomic="true"></span>
      </div>
    </div>

    <!-- Results -->
    <div id="search-results" class="search-results" aria-label="Search results"></div>

    <!-- Popular topics -->
    <section class="popular-topics" id="popular-topics" aria-label="Browse popular topics">
      <h2 class="pop-label">🔥 Popular Topics</h2>
      <div class="pop-tags">
        {popularTopics.map((t) => (
          <a href={`/topic/${t}`} class="pop-tag" data-topic={t}>{t}</a>
        ))}
      </div>
    </section>
  </div>
</Base>

<!-- Inject compact search index into the page -->
<script define:vars={{ searchIndex, catMap }}>
  const INDEX = searchIndex;
  const CAT_LABELS = catMap;

  const input = document.getElementById('search-input');
  const clearBtn = document.getElementById('search-clear');
  const catFilter = document.getElementById('cat-filter');
  const results = document.getElementById('search-results');
  const countEl = document.getElementById('search-count');
  const popularSection = document.getElementById('popular-topics');

  // Pre-fill from URL ?q=
  const urlQ = new URLSearchParams(location.search).get('q') ?? '';
  if (urlQ) { input.value = urlQ; }

  function fmt(n) {
    if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
    return String(n);
  }

  function score(item, tokens) {
    let s = 0;
    const name = (item.n + ' ' + item.o).toLowerCase();
    const desc = item.d.toLowerCase();
    const topics = item.t.toLowerCase();
    for (const tok of tokens) {
      if (item.n.toLowerCase() === tok) s += 60;        // exact repo name
      else if (name.startsWith(tok)) s += 40;           // starts with
      else if (name.includes(tok)) s += 20;             // in name
      if (topics.split(' ').includes(tok)) s += 15;    // exact topic
      else if (topics.includes(tok)) s += 8;            // partial topic
      if (desc.includes(tok)) s += 4;                   // description
    }
    return s;
  }

  function search() {
    const q = input.value.trim().toLowerCase();
    const cat = catFilter.value;
    const tokens = q.split(/\s+/).filter(Boolean);

    clearBtn.hidden = !q;

    if (!q && !cat) {
      results.innerHTML = '';
      if (countEl) countEl.textContent = '';
      if (popularSection) popularSection.hidden = false;
      return;
    }

    if (popularSection) popularSection.hidden = true;

    let pool = INDEX.slice();
    if (cat) pool = pool.filter(i => i.c === cat);

    let scored = pool;
    if (tokens.length > 0) {
      scored = pool
        .map(item => ({ item, s: score(item, tokens) }))
        .filter(r => r.s > 0)
        .sort((a, b) => b.s - a.s || b.item.s - a.item.s)
        .map(r => r.item);
    } else {
      scored = scored.sort((a, b) => b.s - a.s);
    }

    const shown = scored.slice(0, 40);
    if (countEl) countEl.textContent = `${scored.length.toLocaleString()} result${scored.length !== 1 ? 's' : ''}`;

    if (shown.length === 0) {
      results.innerHTML = `<div class="no-results">
        <p>No repos found for <strong>"${q}"</strong>${cat ? ' in ' + (CAT_LABELS[cat] ?? cat) : ''}.</p>
        <p>Try a shorter keyword or <a href="/search">clear the search</a>.</p>
      </div>`;
      return;
    }

    results.innerHTML = `<ul class="result-list" role="list">
      ${shown.map(r => `
        <li>
          <a href="/repo/${r.o}/${r.n}" class="result-card">
            <div class="rc-header">
              <div class="rc-name">
                <span class="rc-owner">${r.o}/</span><strong class="rc-repo">${r.n}</strong>
              </div>
              <div class="rc-stars">⭐ ${fmt(r.s)}</div>
            </div>
            ${r.d ? `<p class="rc-desc">${r.d.length > 120 ? r.d.slice(0, 120) + '…' : r.d}</p>` : ''}
            <div class="rc-footer">
              ${r.l ? `<span class="rc-pill">● ${r.l}</span>` : ''}
              ${r.c ? `<a href="/category/${r.c}" class="rc-pill rc-pill--cat" onclick="event.stopPropagation()">${CAT_LABELS[r.c] ?? r.c}</a>` : ''}
            </div>
          </a>
        </li>
      `).join('')}
    </ul>`;
  }

  // Debounce
  let timer;
  input.addEventListener('input', () => { clearTimeout(timer); timer = setTimeout(search, 180); });
  catFilter.addEventListener('change', search);
  clearBtn.addEventListener('click', () => { input.value = ''; catFilter.value = ''; search(); input.focus(); });

  // Topic quick-search
  document.querySelectorAll('.pop-tag').forEach(a => {
    a.addEventListener('click', (e) => {
      const topic = a.dataset.topic;
      if (!topic) return;
      // Don't navigate — search instead
      e.preventDefault();
      input.value = topic;
      search();
      input.focus();
    });
  });

  // Update URL on search
  input.addEventListener('input', () => {
    const q = input.value.trim();
    const url = q ? `?q=${encodeURIComponent(q)}` : location.pathname;
    history.replaceState(null, '', url);
  });

  // Run initial search if ?q= present
  if (urlQ) search();
</script>

<style>
  .search-page { padding-block: 2.5rem 5rem; max-width: 760px; margin-inline: auto; }

  .search-header { text-align: center; margin-bottom: 2rem; }
  .search-title { font-size: clamp(1.875rem, 5vw, 3rem); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.5rem; }
  .grad { background: linear-gradient(135deg, var(--color-accent), #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .search-subtitle { font-size: 1rem; color: var(--color-text-muted); }

  /* Search box */
  .search-box-wrap {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    transition: box-shadow 0.2s;
  }
  .search-box-wrap:focus-within {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  .search-input-row {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .search-icon { display: flex; align-items: center; color: var(--color-text-muted); flex-shrink: 0; cursor: pointer; }
  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 1rem 0.75rem;
    font-size: 1.0625rem;
    color: var(--color-text);
    outline: none;
    font-family: inherit;
    min-width: 0;
  }
  .search-input::placeholder { color: var(--color-text-muted); }
  .search-input::-webkit-search-cancel-button { display: none; }

  .search-clear {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.12s, color 0.12s;
  }
  .search-clear:hover { background: var(--color-accent-light); color: var(--color-accent); }
  .search-clear[hidden] { display: none; }

  .filter-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    
  }
  .filter-label { font-size: 0.8125rem; font-weight: 500; color: var(--color-text-muted); white-space: nowrap; }
  .filter-select {
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: 8px;
    padding: 0.3rem 0.625rem;
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    flex: 1;
    min-width: 160px;
    max-width: 280px;
  }
  .search-count {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: auto;
    white-space: nowrap;
  }

  /* Results */
  :global(.result-list) { list-style: none; display: flex; flex-direction: column; gap: 0.625rem; }
  :global(.result-card) {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding: 1rem; background: var(--color-bg);
    border: 1px solid var(--color-border); border-radius: 12px;
    text-decoration: none; color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.12s, transform 0.12s;
  }
  :global(.result-card:hover) { border-color: var(--color-accent); box-shadow: 0 2px 12px color-mix(in srgb, var(--color-accent) 10%, transparent); transform: translateY(-1px); }
  :global(.rc-header) { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; }
  :global(.rc-owner) { font-size: 0.8125rem; color: var(--color-text-muted); }
  :global(.rc-repo) { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); }
  :global(.rc-stars) { font-size: 0.8125rem; font-weight: 700; color: #f59e0b; flex-shrink: 0; }
  :global(.rc-desc) { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.55; }
  :global(.rc-footer) { display: flex; gap: 0.375rem;  }
  :global(.rc-pill) { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.15rem 0.5rem; border-radius: 100px; font-size: 0.6875rem; font-weight: 500; background: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border); text-decoration: none; }
  :global(.rc-pill--cat) { background: var(--color-accent-light); color: var(--color-accent); border-color: transparent; }
  :global(.rc-pill--cat:hover) { opacity: 0.8; }

  :global(.no-results) { text-align: center; padding: 3rem 1rem; color: var(--color-text-muted); }
  :global(.no-results strong) { color: var(--color-text); }
  :global(.no-results a) { color: var(--color-accent); }

  /* Popular topics */
  .popular-topics { margin-top: 2rem; }
  .pop-label { font-size: 0.875rem; font-weight: 700; color: var(--color-text-muted); margin-bottom: 0.75rem; }
  .pop-tags { display: flex;  gap: 0.375rem; }
  .pop-tag {
    display: inline-block; padding: 0.3rem 0.7rem; border-radius: 100px;
    font-size: 0.8125rem; font-weight: 500;
    background: var(--color-surface); color: var(--color-text-muted);
    border: 1px solid var(--color-border); text-decoration: none; cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .pop-tag:hover { background: var(--color-accent-light); color: var(--color-accent); border-color: var(--color-accent); }
</style>
