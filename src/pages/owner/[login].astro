---
/**
 * /owner/[login] — All repos by a specific GitHub owner or org.
 * Generated for every unique owner in the manifest.
 */
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/navigation/Breadcrumb.astro';
import { buildCollectionPageSchema } from '../../utils/schema';
import manifestRaw from '../../data/manifest.json';

interface RepoEntry {
  full_name: string; owner: string; repo: string; stars: number;
  forks: number; language?: string; topics: string[];
  primary_category: string; pushed_at: string; description?: string;
}

export async function getStaticPaths() {
  const manifest: RepoEntry[] = manifestRaw as any;
  const uniqueLogins = [...new Set(manifest.map(r => r.owner.toLowerCase()))];

  return uniqueLogins.map((login) => ({
    params: { login },
    props: { login }
  }));
}

const { login } = Astro.props;
const manifest: RepoEntry[] = manifestRaw as any;
const repos = manifest
  .filter(r => r.owner.toLowerCase() === login)
  .sort((a, b) => b.stars - a.stars);



const SITE = 'https://aipromptsmall.shop';
const canonical = `${SITE}/owner/${login}`;

// Try to find avatar from first repo's owner data — we check the repos glob
// Fallback to GitHub's avatar service (no auth needed for public avatars)
const avatarUrl = `https://github.com/${login}.png?size=128`;

const totalStars = repos.reduce((s, r) => s + r.stars, 0);
const languages = [...new Set(repos.map((r) => r.language).filter(Boolean))];

const schema = buildCollectionPageSchema({
  name: `${login} — AI Tools on GitHub`,
  description: `${repos.length} open-source AI repositories by ${login} on GitHub, with ${totalStars.toLocaleString()} total stars.`,
  url: canonical,
  numberOfItems: repos.length,
});

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: login, href: `/owner/${login}` },
];

function fmt(n: number) {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}k`;
  return String(n);
}
function relDate(iso: string) {
  const days = Math.floor((Date.now() - new Date(iso).getTime()) / 86400000);
  if (days === 0) return 'today';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  return `${Math.floor(days / 30)}mo ago`;
}
---

<Base
  title={`${login} — ${repos.length} AI Repos | aipromptsmall.shop`}
  description={`${repos.length} open-source AI repositories by ${login} with ${totalStars.toLocaleString()}+ total GitHub stars.`}
  canonical={canonical}
  pageType="owner"
  schemas={[schema]}
>
  <Breadcrumb crumbs={breadcrumbs} />

  <div class="owner-page container">

    <!-- Owner profile card -->
    <header class="owner-card">
      <img
        src={avatarUrl}
        alt={`${login} avatar`}
        width="80"
        height="80"
        class="owner-avatar"
        loading="eager"
        onerror="this.style.display='none'"
      />
      <div class="owner-info">
        <h1 class="owner-login">{login}</h1>
        <p class="owner-meta">
          <span class="owner-stat">📦 <strong>{repos.length}</strong> repos</span>
          <span class="owner-stat">⭐ <strong>{fmt(totalStars)}</strong> total stars</span>
          {languages.length > 0 && (
            <span class="owner-stat">🔵 {languages.slice(0, 3).join(', ')}{languages.length > 3 ? ` +${languages.length - 3}` : ''}</span>
          )}
        </p>
        <div class="owner-actions">
          <a
            href={`https://github.com/${login}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-github-sm"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            View on GitHub
          </a>
        </div>
      </div>
    </header>

    <!-- Repos grid -->
    <section aria-label={`${login}'s repositories`}>
      <h2 class="section-label">Repositories ({repos.length})</h2>
      <ul class="repo-grid" role="list">
        {repos.map((r) => (
          <li>
            <a href={`/repo/${r.owner}/${r.repo}`} class="repo-card">
              <div class="rc-header">
                <strong class="rc-repo">{r.repo}</strong>
                <div class="rc-stars">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {fmt(r.stars)}
                </div>
              </div>
              {r.description && (
                <p class="rc-desc">{r.description.length > 110 ? `${r.description.slice(0, 110)}…` : r.description}</p>
              )}
              <div class="rc-footer">
                <div class="rc-pills">
                  {r.language && <span class="rc-pill"><span class="lang-dot" aria-hidden="true"></span>{r.language}</span>}
                </div>
                <time class="rc-time" datetime={r.pushed_at}>{relDate(r.pushed_at)}</time>
              </div>
              {r.topics.length > 0 && (
                <div class="rc-topics">
                  {r.topics.slice(0, 3).map((t) => (
                    <a href={`/topic/${t}`} class="rc-topic" onclick="event.stopPropagation()">{t}</a>
                  ))}
                  {r.topics.length > 3 && <span class="rc-topic rc-topic--more">+{r.topics.length - 3}</span>}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Base>

<style>
  .owner-page { padding-block: 1.5rem 5rem; }

  .owner-card {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    margin-bottom: 2rem;
  }
  .owner-avatar { width: 80px; height: 80px; border-radius: 50%; border: 3px solid var(--color-border); flex-shrink: 0; }
  .owner-login { font-size: clamp(1.375rem, 4vw, 2rem); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.375rem; }
  .owner-meta { display: flex; gap: 1rem;  margin-bottom: 0.875rem; }
  .owner-stat { font-size: 0.875rem; color: var(--color-text-muted); }
  .owner-stat strong { color: var(--color-text); }

  .btn-github-sm {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.875rem;
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: 8px;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-github-sm:hover { opacity: 0.85; }

  .section-label { font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: 1rem; }
  .repo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; list-style: none; }
  .repo-card {
    display: flex; flex-direction: column; gap: 0.625rem;
    padding: 1rem; background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: 12px; text-decoration: none; color: var(--color-text); margin-bottom: auto;
    transition: border-color 0.15s, transform 0.12s;
  }
  .repo-card:hover { border-color: var(--color-accent); transform: translateY(-2px); }
  .rc-header {  display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem;  }
  
  .rc-repo { font-size: 0.9375rem; font-weight: 700; word-break: break-word; color: var(--color-text); }
  .rc-stars { display: flex; align-items: center; gap: 0.25rem; font-size: 0.8125rem; font-weight: 700; color: #f59e0b; flex-shrink: 0; }
  .rc-desc { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.55; flex: 1;}
  .rc-footer { display: flex; align-items: center; justify-content: space-between;  }
  .rc-pills { display: flex; gap: 0.375rem;  }
  .rc-pill { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.15rem 0.5rem; border-radius: 100px; font-size: 0.6875rem; font-weight: 500; background: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border); }
  .lang-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; }
  .rc-time { font-size: 0.6875rem; color: var(--color-text-muted); }
  .rc-topics { display: flex; gap: 0.3rem;  }
  .rc-topic { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 100px; font-size: 0.6875rem; font-weight: 500; background: var(--color-accent-light); color: var(--color-accent); text-decoration: none;     }
  .rc-topic:hover { opacity: 0.75; }
  .rc-topic--more { background: var(--color-surface-2); color: var(--color-text-muted); border: 1px solid var(--color-border); }

  @media (max-width: 600px) {
    .owner-card { flex-direction: column; align-items: center; text-align: center; }
    .owner-meta { justify-content: center; }
  }
</style>
